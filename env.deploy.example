# --- Vercel (هنگام Build فرانت) ---
# در پروژه Vercel → Settings → Environment Variables → همه محیط‌ها (Production / Preview)
VITE_API_BASE_URL=https://SUBDOMAIN.onrender.com

# --- Render (Web Service بک‌اند) ---
NODE_ENV=production
JWT_SECRET=حداقل-۳۲-کاراکتر-تصادفی-اینجا
ALLOWED_ORIGINS=https://dokanyar.vercel.app
# اگر هنوز Failed to fetch و CORS: true بگذار تا هر https://*.vercel.app (شامل preview) مجاز شود
CORS_ALLOW_VERCEL_APP=true
RECAPTCHA_REQUIRED_IN_PROD=false
DATABASE_URL=file:./server/prisma/dev.db

# ساده‌ترین حالت: فقط این یکی (به‌جای سه متغیر SEED_* جدا)
SEED_BOOTSTRAP=یک-رمز-قوی-حداقل-۱۶-کاراکتر

# یا جداگانه (اگر SEED_BOOTSTRAP نگذاشتی هر سه لازم‌اند):
# SEED_SUPERADMIN_PASSWORD=...
# SEED_RESET_CODE=...
# SEED_PENDING_USER_PASSWORD=...

# اگر reCAPTCHA را فعال کردید:
# RECAPTCHA_SECRET_KEY=...
