{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node --no-warnings server/index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "vite build",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android:debug": "npm run cap:sync && cd android && .\\gradlew.bat assembleDebug",
    "android:release": "npm run cap:sync && cd android && .\\gradlew.bat assembleRelease",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@react-oauth/google": "^0.13.4",
    "@types/bcryptjs": "^2.4.6",
    "@zxing/library": "^0.21.3",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "clsx": "2.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.3",
    "otplib": "^13.4.0",
    "prisma": "^7.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.72.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "tailwind-merge": "3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.1.17",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-google-recaptcha": "^2.1.9",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "5.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^10.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "4.1.17",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^4.1.0"
  }
}
