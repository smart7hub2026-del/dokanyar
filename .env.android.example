# کپی کنید به .env.local قبل از: npm run build && npm run cap:sync
# شبیه‌ساز اندروید → بک‌اند روی همان PC (پورت پیش‌فرض 4000):
VITE_API_BASE_URL=http://10.0.2.2:4000
# گوشی واقعی (همان وای‌فای) — IP کامپیوترتان را بگذارید:
# VITE_API_BASE_URL=http://192.168.1.10:4000
# سرور روی اینترنت (HTTPS):
# VITE_API_BASE_URL=https://api.example.com
