# ── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# REQUIRED: Change this to a long random string in production
JWT_SECRET=dokanyar-dev-secret-2026-change-in-production

# Frontend origin(s) allowed by CORS
ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# خالی بگذارید: همهٔ درخواست‌های /api از همان آدرسی که صفحه باز شده (مثلاً http://IP:5173) می‌روند
# و Vite آن‌ها را به backend روی این ماشین پروکسی می‌کند. اگر اینجا localhost:4000 بگذارید،
# روی موبایل «localhost» یعنی خود گوشی → Failed to fetch.
VITE_API_BASE_URL=

# Google OAuth — get from console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ── HesabPay (hesab.com) ─────────────────────────────────────────────────────
HESABPAY_API_KEY=
HESABPAY_WEBHOOK_SECRET=

# ── Gmail (for sending welcome/notification emails) ──────────────────────────
# Setup: Google Account → Security → 2-Step Verification → App passwords → Generate 16-char password
GMAIL_USER=
GMAIL_APP_PASSWORD=

# OTP sender for demo registration (defaults to GMAIL_USER if not set)
OTP_GMAIL_USER=smart7hub2026@gmail.com
OTP_GMAIL_APP_PASSWORD=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./server/prisma/dev.db

# ── Auth hardening ───────────────────────────────────────────────────────────
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQ=120

# ── Seed credentials ─────────────────────────────────────────────────────────
SEED_SHOP001_PASSWORD=shop123
SEED_SHOP002_PASSWORD=shop456
SEED_SUPERADMIN_PASSWORD=super-secret-2026
SEED_DEFAULT_ROLE_PASSWORD=1234
SEED_RESET_CODE=12345678
